{
  "name": "composite-model",
  "version": "0.1.0",
  "description": "Frontend utilities and runtime loader for JSONL composite Live2D models.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "jsonl",
    "live2d",
    "pixi",
    "webgal",
    "composite-model"
  ],
  "license": "MIT",
  "peerDependencies": {
    "pixi-live2d-display-webgal": "^0.5.12",
    "pixi.js": "^6.5.10"
  },
  "devDependencies": {
    "@types/node": "^24.2.1",
    "pixi-live2d-display-webgal": "^0.5.12",
    "pixi.js": "^6.5.10",
    "tsup": "^8.3.5",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  }
}
