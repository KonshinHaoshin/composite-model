{
  "name": "composite-model",
  "version": "0.1.1",
  "description": "前端 JSONL 聚合模型工具包，统一解析、优化并加载 Live2D、图片、GIF 与 WebM 复合立绘。",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "example:dev": "vite --config examples/basic/vite.config.ts",
    "example:build": "vite build --config examples/basic/vite.config.ts"
  },
  "keywords": [
    "jsonl",
    "live2d",
    "pixi",
    "gif",
    "webm",
    "webgal",
    "composite-model"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@pixi/gif": "^1.1.3",
    "pixi-live2d-display-webgal": "^0.5.12",
    "pixi.js": "^6.5.10"
  },
  "peerDependenciesMeta": {
    "@pixi/gif": {
      "optional": true
    }
  },
  "devDependencies": {
    "@pixi/gif": "^1.1.3",
    "@types/node": "^24.2.1",
    "pixi-live2d-display-webgal": "^0.5.12",
    "pixi.js": "^6.5.10",
    "tsup": "^8.3.5",
    "typescript": "^5.8.3",
    "vite": "^7.1.11",
    "vitest": "^2.1.8"
  },
  "repository": {
  "type": "git",
  "url": "https://github.com/KonshinHaoshin/composite-model"
  },
  "homepage": "https://github.com/KonshinHaoshin/composite-model#readme",
  "bugs": {
    "url": "https://github.com/KonshinHaoshin/composite-model/issues"
  }
}
